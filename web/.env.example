# Shadow Web — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# ── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model overrides (optional — defaults used if omitted)
# Classification and chat: gpt-4o-mini
# Reports and deep queries: gpt-4o
OPENAI_CLASSIFY_MODEL=gpt-4o-mini
OPENAI_REPORT_MODEL=gpt-4o

# ── Cost Control ────────────────────────────────────────────────────────────
# Max LLM spend per user per day in USD (default: 1.50)
MAX_DAILY_LLM_USD=1.50

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3007

# ── Spotify (optional — only needed for music tracking feature) ─────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3007/api/auth/spotify/callback

# ── Encryption ──────────────────────────────────────────────────────────────
# 32-char random string for token encryption. Generate: openssl rand -hex 16
TOKEN_ENCRYPTION_KEY=
