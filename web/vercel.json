{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/reports/daily/route.ts":   { "maxDuration": 60 },
    "src/app/api/reports/weekly/route.ts":  { "maxDuration": 60 },
    "src/app/api/shadow/chat/route.ts":     { "maxDuration": 30 },
    "src/app/api/memory/ask/route.ts":      { "maxDuration": 30 },
    "src/app/api/labs/sessions/[id]/complete/route.ts": { "maxDuration": 60 },
    "src/app/api/embed/route.ts":           { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.openai.com; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
